{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Calendar Knowledge App",
  "version": "0.1.0",
  "identifier": "com.local.calendar-knowledge-app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:5173",
